<Window x:Class="ChatApp.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatApp.Client"
        mc:Ignorable="d"
        Title="ChatApp" Height="500" Width="700" MinHeight="350" MinWidth="450">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
        <local:UtcToLocalTimeConverter x:Key="UtcToLocalTime" />
    </Window.Resources>
    <Grid>

        <!-- Join panel -->
        <StackPanel Width="280" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="{Binding IsJoined, Converter={StaticResource InverseBoolToVisibility}}">
            <TextBlock Text="Join the chat" FontSize="20" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,12" />
            <TextBox Padding="6" MaxLength="32"
                     Text="{Binding Username, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.InputBindings>
                    <KeyBinding Key="Return" Command="{Binding JoinCommand}" />
                </TextBox.InputBindings>
            </TextBox>
            <Button Content="Join" Padding="6" Margin="0,8,0,0" Command="{Binding JoinCommand}" />
            <TextBlock Text="{Binding Status}" Margin="0,8,0,0" TextWrapping="Wrap"
                       HorizontalAlignment="Center" Foreground="DarkRed" />
        </StackPanel>

        <!-- Chat panel -->
        <Grid Margin="8" Visibility="{Binding IsJoined, Converter={StaticResource BoolToVisibility}}">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ListBox x:Name="MessageList" ItemsSource="{Binding Messages}"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock TextWrapping="Wrap">
                            <Run Foreground="Gray"
                                 Text="{Binding SentAt, Converter={StaticResource UtcToLocalTime}, StringFormat='HH:mm', Mode=OneWay}" />
                            <Run FontWeight="SemiBold" Text="{Binding Username, Mode=OneWay}" /><Run Text=":" />
                            <Run Text="{Binding Content, Mode=OneWay}" />
                        </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <Grid Grid.Row="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Padding="6" MaxLength="2000"
                         Text="{Binding MessageText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.InputBindings>
                        <KeyBinding Key="Return" Command="{Binding SendCommand}" />
                    </TextBox.InputBindings>
                </TextBox>
                <Button Grid.Column="1" Content="Send" Padding="12,6" Margin="8,0,0,0"
                        Command="{Binding SendCommand}" />
            </Grid>

            <TextBlock Grid.Row="2" Text="{Binding Status}" Margin="0,6,0,0" Foreground="Gray" />
        </Grid>

    </Grid>
</Window>
